  },
  "dependencies": {
    "@agentclientprotocol/sdk": "catalog:",
    "@corporation/config": "workspace:*",
    "@corporation/contracts": "workspace:*",
    "@hono/zod-validator": "^0.7.6",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "bun-types": "latest",
    "dotenv": "catalog:",
    "e2b": "catalog:",
    "typescript": "catalog:"
  }
}
