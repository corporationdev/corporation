{
  "name": "sandbox-runtime",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./client": "./src/client.ts",
    "./proxy-config": "./src/proxy-config.ts",
    "./schemas": "./src/schemas.ts"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "test": "bun run test:local",
