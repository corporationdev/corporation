  "scripts": {
    "dev": "STAGE_VALUE=${STAGE:-$(awk -F= '/^STAGE=/{print $2; exit}' .env 2>/dev/null)}; case \"$STAGE_VALUE\" in sandbox|sandbox-*) CONVEX_DEPLOY_KEY='<ignore_deploy_key>' CONVEX_AGENT_MODE=anonymous convex dev --local ;; *) convex dev ;; esac",
    "dev:setup": "convex dev --configure --until-success",
    "auth:generate": "cd convex/betterAuth && bunx @better-auth/cli@latest generate --output ./schema.ts -y"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "catalog:",
    "@convex-dev/better-auth": "catalog:",
    "@tendril/shared": "workspace:*",
    "@nangohq/node": "catalog:",
    "ai": "catalog:",
    "better-auth": "catalog:",
    "convex": "catalog:",
    "convex-helpers": "catalog:",
    "dotenv": "catalog:",
    "e2b": "catalog:",
    "nanoid": "catalog:",
    "resend": "^6.9.3",
    "svix": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tendril/config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
