# 1Password-backed secrets template.
# Runtime URLs/proxies are derived from STAGE at runtime via @tendril/config.
# ENV_TIER is derived from STAGE as one of: dev, preview, prod.
STAGE=${STAGE}

# Alchemy
ALCHEMY_PASSWORD=op://tendril-${ENV_TIER}/Alchemy/password
ALCHEMY_STATE_TOKEN=op://tendril-${ENV_TIER}/Alchemy/state-token
CLOUDFLARE_API_TOKEN=op://tendril-${ENV_TIER}/Cloudflare/api-token

# Convex
CONVEX_DEPLOY_KEY=op://tendril-${ENV_TIER}/Convex/deploy-key
CONVEX_MANAGEMENT_TOKEN=op://tendril-${ENV_TIER}/Convex/team-access-token

# Auth
BETTER_AUTH_SECRET=op://tendril-${ENV_TIER}/Better Auth/secret
INTERNAL_API_KEY=op://tendril-${ENV_TIER}/Better Auth/internal-api-key
API_KEY_MASTER_KEY=op://tendril-${ENV_TIER}/Better Auth/api-key-master-key
RUNTIME_AUTH_SECRET=op://tendril-${ENV_TIER}/Better Auth/runtime-auth-secret

# Email
RESEND_API_KEY=op://tendril-${ENV_TIER}/Resend/api-key

# AI
ANTHROPIC_API_KEY=op://tendril-${ENV_TIER}/Anthropic/api-key
OPENAI_API_KEY=op://tendril-${ENV_TIER}/OpenAI/api-key
OPENCODE_API_KEY=op://tendril-${ENV_TIER}/OpenCode/api-key

# Integrations
NANGO_SECRET_KEY=op://tendril-${ENV_TIER}/Nango/secret-key

# Sandbox
E2B_API_KEY=op://tendril-${ENV_TIER}/E2B/api-key
E2B_WEBHOOK_SECRET=op://tendril-${ENV_TIER}/E2B/webhook-secret
