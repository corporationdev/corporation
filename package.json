{
  "name": "tendril",
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@tendril/config": "workspace:*",
    "@types/bun": "^1.3.9",
    "@types/node": "catalog:",
    "dotenv": "catalog:",
    "e2b": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "ultracite": "7.2.4"
  },
  "packageManager": "bun@1.3.8",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "test": "turbo test",
    "secrets:inject": "bun scripts/secrets-inject.ts",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:server": "turbo -F @tendril/backend dev",
    "dev:agent": "turbo -F @tendril/infra dev",
    "dev:setup": "turbo -F @tendril/backend dev:setup",
    "deploy": "turbo -F @tendril/infra deploy",
    "destroy": "turbo -F @tendril/infra destroy",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "fix:force": "ultracite fix --unsafe",
    "db:generate": "turbo db:generate",
    "setup": "bun scripts/setup.ts",
    "build:sandbox-runtime": "bun scripts/build-sandbox-runtime.ts",
    "pack:sandbox-runtime": "bun scripts/pack-sandbox-runtime.ts",
    "publish:sandbox-runtime": "bun scripts/publish-sandbox-runtime.ts",
    "dev:sandbox-runtime": "bun scripts/dev-sandbox-runtime.ts",
    "dev:cli": "STAGE_VALUE=${STAGE:-$(awk -F= '/^STAGE=/{print $2; exit}' .env 2>/dev/null)}; if [ -z \"$STAGE_VALUE\" ]; then echo 'Missing STAGE. Set STAGE in the environment or .env.'; exit 1; fi; STAGE=$STAGE_VALUE bun packages/cli/cli/index.ts",
    "dev:runtime-server": "bun packages/cli/dev-server.ts",
    "sandbox:create-agent-install": "bun scripts/create-agent-install-sandbox.ts",
    "rebuild:template": "bun scripts/build-base-template.ts",
    "generate:agents": "bun scripts/generate-acp-agents.ts",
    "test:server": "bun run --filter @tendril/server test",
    "test:e2e": "bun run --filter @tendril/server test:e2e",
    "auth:generate": "turbo -F @tendril/backend auth:generate"
  },
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@agentclientprotocol/sdk": "^0.15.0",
      "@base-ui/react": "^1.0.0",
      "@better-auth/api-key": "^1.5.5",
      "@cloudflare/workers-types": "^4.20251213.0",
      "@convex-dev/better-auth": "^0.11.1",
      "@e2b/desktop": "^2.2.2",
      "e2b": "^2.13.0",
      "effect": "4.0.0-beta.30",
      "@hono/zod-openapi": "^1.2.1",
      "@effect/platform-bun": "4.0.0-beta.30",
      "@nangohq/node": "^0.69.31",
      "@orpc/client": "^1.13.6",
      "@orpc/contract": "^1.13.6",
      "@orpc/server": "^1.13.6",
      "@orpc/tanstack-query": "^1.13.6",
      "@radix-ui/react-slot": "^1.2.4",
      "@t3-oss/env-core": "^0.13.1",
      "@tailwindcss/vite": "^4.0.15",
      "@tanstack/react-form": "^1.12.3",
      "@tanstack/react-query": "^5.90.2",
      "@tanstack/react-router": "^1.141.1",
      "@tanstack/react-router-devtools": "^1.141.1",
      "@tanstack/router-plugin": "^1.141.1",
      "@types/node": "^24.3.0",
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3",
      "@uidotdev/usehooks": "^2.4.1",
      "@vitejs/plugin-react": "^4.3.4",
      "ghostty-web": "^0.4.0",
      "alchemy": "^0.82.1",
      "better-auth": "1.5.5",
      "class-variance-authority": "^0.7.1",
      "clsx": "^2.1.1",
      "commander": "^14.0.1",
      "convex": "^1.33.1",
      "convex-helpers": "^0.1.111",
      "dotenv": "^17.2.2",
      "electron": "^40.1.0",
      "electron-vite": "^5.0.0",
      "drizzle-kit": "^0.31.9",
      "drizzle-orm": "^0.45.1",
      "hono": "^4.8.2",
      "jose": "^6.1.0",
      "lucide-react": "^0.473.0",
      "nanoid": "^5.1.6",
      "next-themes": "^0.4.6",
      "octokit": "^5.0.5",
      "pino": "^10.3.0",
      "pino-pretty": "^13.1.3",
      "postcss": "^8.5.3",
      "react": "19.2.3",
      "react-dom": "19.2.3",
      "react-resizable-panels": "^4.6.4",
      "remark-gfm": "^4.0.1",
      "shadcn": "^3.6.2",
      "sonner": "^2.0.5",
      "@streamdown/code": "^1.0.3",
      "streamdown": "^2.1.0",
      "svix": "^1.86.0",
      "tailwind-merge": "^3.3.1",
      "tailwindcss": "^4.0.15",
      "turbo": "^2.6.3",
      "tw-animate-css": "^1.2.5",
      "typescript": "^5",
      "wrangler": "^4.72.0",
      "vite": "^6.2.2",
      "zod": "^4.1.13",
      "zustand": "^5.0.11",
      "@ai-sdk/anthropic": "^3.0.53",
      "@ai-sdk/react": "^3.0.118",
      "ai": "^6.0.108"
    }
  }
}
